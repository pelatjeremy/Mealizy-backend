{
  "name": "@mealizy/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.9.2",
  "scripts": {
    "dev": "nodemon src/server.js",
    "build": "node -e \"console.log('No build step required for Mealizy API')\"",
    "start": "node src/server.js",
    "lint": "eslint src --ext .js",
